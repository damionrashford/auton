# ═══════════════════════════════════════════════════════════════════
#  Auton — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── xAI (Grok LLM via xai-sdk) ────────────────────────────────────
XAI_API_KEY=xai-...
XAI_MODEL=grok-4.1-fast
# XAI_TEMPERATURE=
# XAI_MAX_TOKENS=
# XAI_REASONING_EFFORT=low
XAI_EMBEDDING_MODEL=grok-embedding-small

# ── RivalSearchMCP (remote HTTP) ────────────────────────────────────
RIVAL_SEARCH_URL=https://RivalSearchMCP.fastmcp.app/mcp

# ── Playwright MCP (required, local subprocess) ─────────────────────
PLAYWRIGHT_MCP_PORT=8931
PLAYWRIGHT_MCP_HEADLESS=true
PLAYWRIGHT_MCP_BROWSER=chromium
PLAYWRIGHT_MCP_STEALTH=true

# ── Google Workspace MCP (optional) ─────────────────────────────────
# taylorwilsdon/google_workspace_mcp — all tools auto-prefixed with gw_
GOOGLE_WORKSPACE_MCP_URL=http://localhost:8001/mcp
GOOGLE_WORKSPACE_MCP_ENABLED=true

# ── Slack (primary UI + outbound tools) ─────────────────────────────
# Slack is the main interface — @mention the bot or DM it to talk to
# the multi-agent system.  Uses Socket Mode (no public URL needed).
#
# Setup at https://api.slack.com/apps :
#   1. Create app → "From scratch"
#   2. Socket Mode → Enable → generate SLACK_APP_TOKEN (xapp-...)
#   3. OAuth & Permissions → Bot Token Scopes:
#        app_mentions:read, chat:write, channels:history, channels:read,
#        im:history, im:read, im:write, search:read, reactions:write,
#        users:read, users:read.email, files:write
#   4. Event Subscriptions → Enable → Subscribe to:
#        app_mention, message.im
#   5. Install to Workspace → copy SLACK_BOT_TOKEN (xoxb-...)
#
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=
SLACK_ENABLED=true

# ── Cron Scheduler (optional) ───────────────────────────────────────
CRON_ENABLED=true
CRON_TIMEZONE=UTC

# ── Neon Postgres (persistent storage) ──────────────────────────────
# Connection string from your Neon dashboard. Leave empty for in-memory
# fallback (conversations will not persist across restarts).
NEON_DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require
NEON_API_KEY=

# ── Redis (required — caching, session state, background tasks) ────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_SESSION_DB=1
DOCKET_URL=redis://localhost:6379/2

# ── Coinbase AgentKit (optional) ───────────────────────────────────
# Blockchain operations: wallets, DeFi, swaps, NFTs, streaming
# Get API keys from https://portal.cdp.coinbase.com/
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_NETWORK=base-mainnet
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# ── Agent Behavior ──────────────────────────────────────────────────
MAX_ITERATIONS=25
MAX_TOOL_RESULT_LENGTH=15000
TOOL_TIMEOUT=120.0

# ── Context Window Management ───────────────────────────────────────
CONTEXT_WINDOW_LIMIT=128000
COMPACTION_THRESHOLD=0.75
COMPACTION_TAIL_MESSAGES=10

# ── Cost and Safety Guardrails ──────────────────────────────────────
MAX_COST_PER_CONVERSATION=1.0
MAX_COST_PER_DAY=10.0
MAX_TOKENS_PER_CONVERSATION=500000
REQUIRE_CONFIRMATION=true

# ── Server ──────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
